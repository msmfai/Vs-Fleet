              "format": "uint32",
              "minimum": 0.0,
              "type": "integer"
            },
            "session_id": {
              "type": "string"
            },
            "type": {
              "enum": [
                "run.added"
              ],
              "type": "string"
            }
          },
          "required": [
            "run",
            "schema_version",
            "session_id",
            "type"
          ],
          "type": "object"
        },
        {
          "description": "A run changed.",
          "properties": {
            "run": {
              "$ref": "#/definitions/AgentRun"
            },
            "schema_version": {
              "format": "uint32",
              "minimum": 0.0,
              "type": "integer"
            },
            "session_id": {
              "type": "string"
            },
            "type": {
              "enum": [
                "run.updated"
              ],
              "type": "string"
            }
          },
          "required": [
