{
  "name": "fleet-bridge",
  "displayName": "Fleet Bridge",
  "description": "Command bridge: lets the Fleet multiplexer drive this VS Code via vscode.commands.executeCommand.",
  "version": "0.2.0",
  "private": true,
  "publisher": "fleet-team",
  "license": "MIT",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./out/extension.js",
  "extensionKind": [
    "workspace"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": true
    }
  },
  "contributes": {},
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf out",
    "test": "vitest run",
    "coverage": "vitest run --coverage"
  },
  "dependencies": {
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@types/vscode": "^1.125.0",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^4.1.9",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
