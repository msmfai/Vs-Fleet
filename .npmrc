# Root pnpm config (mirrors pnpm-workspace.yaml so it also applies on pnpm 9,
# where the build-script-approval / verify-deps settings are read from .npmrc
# rather than pnpm-workspace.yaml).
#
# The sole workspace member, packages/extension, is an npm-managed VS Code
# extension (own package-lock.json + npm node_modules + tsc/jest/eslint). pnpm
# only orchestrates its per-package scripts via `pnpm -r build/test/lint`; npm
# owns the install. These two settings stop pnpm from fighting that:
#
#  * verify-deps-before-run=false — don't auto-run `pnpm install` before
#    `pnpm run`; install is an explicit, scripts-skipping step.
#  * the build-script gate is satisfied via ignoredBuiltDependencies in
#    pnpm-workspace.yaml; we additionally skip lifecycle scripts on install in
#    CI (`pnpm install --ignore-scripts`) so unrs-resolver@1's postinstall is
#    never run under pnpm (npm runs it for the extension's real node_modules).
verify-deps-before-run=false
